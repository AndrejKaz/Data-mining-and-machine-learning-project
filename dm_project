    "merged_df[\"price_log\"]   = np.log1p(merged_df[\"used_price\"])\n",
    "merged_df[\"price_ratio\"] = merged_df[\"used_price\"] / merged_df[\"used_price\"].median()\n",
    "merged_df[\"hp\"]          = merged_df[\"hp\"].fillna(merged_df[\"hp\"].median())\n",
    "\n",
    "# ── Categorical: encode rarity, generation, series, set ───────────\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "\n",
    "for col in [\"rarity\", \"generation\", \"series\", \"set\"]:\n",
    "    merged_df[col] = merged_df[col].fillna(\"unknown\")\n",
    "    merged_df[col] = LabelEncoder().fit_transform(merged_df[col])\n",
    "\n",
    "# ── attacks: extract count as numeric signal ───────────────────────\n",
    "merged_df[\"attack_count\"] = merged_df[\"attacks\"].apply(\n",
    "    lambda x: len(x) if isinstance(x, list) else 0\n",
    ")\n",
    "\n",
    "# ── release_date: extract year ────────────────────────────────────\n",
    "merged_df[\"release_year\"] = pd.to_datetime(\n",
    "    merged_df[\"release_date\"], errors=\"coerce\"\n",
    ").dt.year.fillna(2000).astype(int)\n",
    "\n",
    "# ── Final feature set ─────────────────────────────────────────────\n",
    "features = [\n",
    "    \"used_price\", \"price_log\", \"price_ratio\",\n",
    "    \"hp\", \"rarity\", \"generation\", \"series\", \"set\",\n",
    "    \"attack_count\", \"release_year\"\n",
    "]\n",
    "\n",
    "x = merged_df[features]\n",
    "y = merged_df[\"graded_price\"]"
